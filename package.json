{
  "name": "ivengo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.4.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @ivengo/db generate",
    "db:push": "pnpm --filter @ivengo/db db:push",
    "db:migrate": "pnpm --filter @ivengo/db migrate",
    "db:seed": "pnpm --filter @ivengo/db seed",
    "db:studio": "pnpm --filter @ivengo/db studio"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0"
  }
}
