# Database
DATABASE_URL="postgresql://ivengo:password@localhost:5432/ivengo_db"

# Redis
REDIS_URL="redis://localhost:6379"

# API
PORT=3001
JWT_SECRET="change-this-to-a-long-random-string-in-production"
ADMIN_PASSWORD="change-this-password"
CORS_ORIGIN="http://localhost:3000"

# Telegram Bot (add multiple channels in DB via admin panel)
TELEGRAM_BOT_TOKEN="your-bot-token-from-botfather"
TELEGRAM_CHANNEL_ID="@your_channel_or_-100xxxxxxxxx"

# AI Generation — pick a provider, no code changes needed
# AI_PROVIDER = anthropic (default) | openrouter | ollama
AI_PROVIDER="anthropic"
AI_MODEL=""               # optional override, e.g. claude-sonnet-4-6 / meta-llama/llama-3.3-70b-instruct / llama3.1

# anthropic provider
ANTHROPIC_API_KEY="sk-ant-..."

# openrouter provider (also gives access to Llama, Mistral, etc. via one key)
OPENROUTER_API_KEY="sk-or-v1-..."
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# ollama provider — local Llama, no API key needed
# OLLAMA_BASE_URL="http://localhost:11434/v1"

# Admin panel
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXTAUTH_SECRET="change-this-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Worker settings
WORKER_INTERVAL_MS=60000
MAX_RETRY_COUNT=3
